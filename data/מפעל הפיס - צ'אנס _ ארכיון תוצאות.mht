@charset "utf-8";

@media print {
  .footer_nav_content { display: none; }
  .footer_app { display: none; }
  .top_section { display: none; }
  .content_share_group { display: none; }
  .content_download_group { display: none; }
  .content_dynamic_button { display: none; }
  .content_group.cat_nav { display: none; }
  .cat_h_content_small, .cat_archive_txt, .select_display_data, .archive_search.w-tabs, .archive_pane.members { display: none; }
}

.w-input:focus, .w-select:focus { box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px; }

.cat_navbar_button:focus { box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px; }

a:focus-visible { box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px; }

.statistic_item:focus-visible { box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px; }

.nav_mobile_button:focus-visible { border: 1px solid rgb(0, 0, 0); }

.mob_drop_link:focus-visible { border: 1px solid rgb(0, 0, 0); }

.mob_drop_button:focus-visible { border: 1px solid rgb(0, 0, 0); }

.inspect_iinsert_item > .inspect_insert_txtfield:focus-visible { border: 1px solid rgb(0, 0, 0); box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px; }

@media (min-width: 950px) and (min-width: 19em) {
  .top_search_desktop { margin-left: 100px; }
}

@media (min-width: 760px) and (min-width: 25em) {
  .search_mobile { margin-left: 100px; }
}

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0px; margin: -1px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); border: 0px; }

.sr-only-focusable:active, .sr-only-focusable:focus { position: static; width: auto; height: auto; margin: 0px; overflow: visible; clip: auto; }

.add_link_archive.inspect:focus { border: 2px solid black !important; box-shadow: rgb(0, 0, 0) 0px 0px 6px 1px !important; }

img { display: inline-block; width: auto; max-width: 100%; min-width: auto; }

.responsive-video { max-width: 100%; height: auto; }

.videoWrapper { position: relative; padding-bottom: 56.25%; padding-top: 25px; height: 0px; }

.videoWrapper iframe { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; }

.list_content_insert ol, #tinymce ol { counter-reset: item 0; padding-right: 35px; }

.list_content_insert ol > li, #tinymce ol > li { display: block; position: relative; direction: rtl; }

.list_content_insert ol > li::before, #tinymce ol > li::before { content: counters(item, ".") ". "; counter-increment: item 1; position: absolute; margin-left: 100%; left: 7px; }

ul { margin: 0px; padding-right: 20px; }

ul.bullet_black_1 { list-style-image: url("../bullets/bullet_black_1.png"); background-color: transparent; }

ul.bullet_black_2 { list-style-image: url("../bullets/bullet_black_2.png"); background-color: transparent; }

ul.bullet_green_1 { list-style-image: url("../bullets/bullet_green_1.png"); background-color: transparent; }

ul.bullet_green_2 { list-style-image: url("../bullets/bullet_green_2.png"); background-color: transparent; }

ul.bullet_grey_1 { list-style-image: url("../bullets/bullet_grey_1.png"); background-color: transparent; }

ul.bullet_grey_2 { list-style-image: url("../bullets/bullet_grey_2.png"); background-color: transparent; }

ul.bullet_orange_1 { list-style-image: url("../bullets/bullet_orange_1.png"); background-color: transparent; }

ul.bullet_orange_2 { list-style-image: url("../bullets/bullet_orange_2.png"); background-color: transparent; }

h2 { }

h3 { }

figure { position: relative; margin-top: 40px; margin-bottom: 40px; padding: 0px; border: 0px solid transparent; width: fit-content; }

figcaption { position: absolute; right: 0px; bottom: 0px; margin: 10px; padding: 3px 15px 5px; background-color: rgb(255, 255, 255); line-height: 24px; }

.w-lightbox-caption { direction: rtl; text-align: right; }

.subscriberAutoComplete { overflow: hidden scroll; max-height: 40%; border-radius: 5px; box-shadow: -2px 4px 8px 0px; text-align: right; direction: rtl; }

.subscriberAutoComplete a { text-decoration: none; }

.hideDivClass { display: none; }

.subscriberPhoneDivDirection { direction: initial !important; }

@media (max-width: 991px) {
  figure { margin-top: 20px; margin-bottom: 20px; font-size: 16px; line-height: 24px; }
  figcaption { margin: 8px; padding: 0px 12px 3px; }
}

@media (max-width: 479px) {
  figure { font-size: 14px; line-height: 22px; }
  figcaption { margin: 6px; padding-right: 8px; padding-bottom: 0px; padding-left: 8px; font-size: 12px; line-height: 18px; }
}

@media (max-width: 991px) {
}

.ui-widget { font-size: 0.8em !important; padding: 0px !important; font-weight: normal !important; }

.ui-datepicker select { font-weight: normal !important; }

.ui-datepicker th { padding: 0px !important; }

.ui-datepicker td { padding: 0px !important; line-height: normal !important; }

@media (max-width: 760px) {
  .ui-datepicker-trigger { padding: 0px; }
}

@media (min-width: 761px) {
  .archive_form_field::placeholder { font-size: 16px; }
}
